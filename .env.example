# ═══════════════════════════════════════════════
# TRIMDOCTOR — Environment Variables
# Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════

# ─── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://trimdoctor.com
NEXT_PUBLIC_APP_NAME=TrimDoctor
NODE_ENV=production

# ─── Anthropic (AI Chatbot + Ad Generation) ────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Stripe (Payments) ─────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Stripe Price IDs
STRIPE_PRICE_SEMAGLUTIDE_INJ_FIRST=price_xxxxx    # $179
STRIPE_PRICE_SEMAGLUTIDE_INJ_ONGOING=price_xxxxx  # $299
STRIPE_PRICE_SEMAGLUTIDE_TAB_FIRST=price_xxxxx    # $149
STRIPE_PRICE_SEMAGLUTIDE_TAB_ONGOING=price_xxxxx  # $249
STRIPE_PRICE_TIRZEPATIDE_FIRST=price_xxxxx         # $249
STRIPE_PRICE_TIRZEPATIDE_ONGOING=price_xxxxx       # $399
STRIPE_PRICE_VIP_COACHING=price_xxxxx              # $1,799

# ─── Database (PostgreSQL on AWS RDS) ──────────
DATABASE_URL=postgresql://user:password@host:5432/trimdoctor?sslmode=require

# ─── OpenLoop Health (Physician Network) ───────
OPENLOOP_API_KEY=xxxxxxxxxxxxx
OPENLOOP_WEBHOOK_SECRET=xxxxxxxxxxxxx

# ─── Belmar Pharmacy ───────────────────────────
BELMAR_API_KEY=xxxxxxxxxxxxx
BELMAR_ACCOUNT_ID=xxxxxxxxxxxxx

# ─── Email (Postmark) ─────────────────────────
POSTMARK_API_KEY=xxxxxxxxxxxxx
POSTMARK_FROM_EMAIL=hello@trimdoctor.com
POSTMARK_TEMPLATE_WELCOME=xxxxx
POSTMARK_TEMPLATE_APPROVED=xxxxx
POSTMARK_TEMPLATE_SHIPPED=xxxxx

# ─── SMS (Twilio) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── HIPAA Compliance (Vanta) ─────────────────
VANTA_API_KEY=xxxxxxxxxxxxx

# ─── Analytics ─────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=xxxxxxxxxxxxx
NEXT_PUBLIC_TIKTOK_PIXEL_ID=xxxxxxxxxxxxx
